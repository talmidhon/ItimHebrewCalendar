<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ItimHebrewCalendar.Windows.ConverterWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ItimHebrewCalendar.Windows">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="40">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" Margin="16,0,0,0">
                <Image x:Name="TitleBarIcon" Width="18" Height="18" VerticalAlignment="Center"/>
                <TextBlock Text="ממיר תאריכים"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1" Margin="24,16,24,8">
            <TextBlock Text="ממיר תאריכים"
                       Style="{ThemeResource TitleTextBlockStyle}"/>
            <TextBlock Text="המרה בין התאריך הלועזי לתאריך העברי"
                       Style="{ThemeResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="2" Padding="24,12,24,24" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16">

                <StackPanel Spacing="8">
                    <TextBlock Text="כיוון ההמרה"
                               Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                    <StackPanel Orientation="Horizontal" Spacing="20">
                        <RadioButton x:Name="RadioGregToHeb"
                                     Content="לועזי > עברי"
                                     IsChecked="True"
                                     GroupName="Direction"
                                     Checked="Direction_Changed"/>
                        <RadioButton x:Name="RadioHebToGreg"
                                     Content="עברי > לועזי"
                                     GroupName="Direction"
                                     Checked="Direction_Changed"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel x:Name="GregInputPanel" Spacing="8">
                    <TextBlock Text="תאריך לועזי"
                               Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                    <CalendarDatePicker x:Name="GregDatePicker"
                                        DateChanged="GregDatePicker_DateChanged"
                                        HorizontalAlignment="Stretch"/>
                </StackPanel>

                <StackPanel x:Name="HebInputPanel" Spacing="8" Visibility="Collapsed">
                    <TextBlock Text="תאריך עברי"
                               Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="1.4*"/>
                            <ColumnDefinition Width="1.1*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="יום"
                                       Style="{ThemeResource CaptionTextBlockStyle}"/>
                            <ComboBox x:Name="HebDayCombo"
                                      HorizontalAlignment="Stretch"
                                      SelectionChanged="HebInput_ChangedCombo"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="חודש"
                                       Style="{ThemeResource CaptionTextBlockStyle}"/>
                            <ComboBox x:Name="HebMonthCombo"
                                      HorizontalAlignment="Stretch"
                                      SelectionChanged="HebInput_ChangedCombo"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Text="שנה"
                                       Style="{ThemeResource CaptionTextBlockStyle}"/>
                            <TextBox x:Name="HebYearBox"
                                     PlaceholderText="תשפ&quot;ו או 5786"
                                     TextChanged="HebInput_TextChanged"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="20,16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="תוצאה"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                   Opacity="0.9"/>
                        <TextBlock x:Name="TxtResultPrimary"
                                   Style="{ThemeResource SubtitleTextBlockStyle}"
                                   Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                   FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtResultSecondary"
                                   Style="{ThemeResource BodyTextBlockStyle}"
                                   Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                   Opacity="0.85"/>
                    </StackPanel>
                </Border>

                <InfoBar x:Name="ErrorBar"
                         IsClosable="False"
                         Severity="Error"
                         IsOpen="False"
                         Title="ערכים לא תקינים"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
