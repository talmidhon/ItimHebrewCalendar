<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ItimHebrewCalendar.Windows.EventEditorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="36">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" Margin="14,0,0,0">
                <Image Source="Assets/AppIcon.png" Width="16" Height="16" VerticalAlignment="Center"/>
                <TextBlock x:Name="TitleBarText"
                           Text="אירוע חדש"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Background="{ThemeResource AccentFillColorDefaultBrush}"
                CornerRadius="8"
                Margin="16,4,16,12"
                Padding="18,10">
            <TextBlock x:Name="HeaderText"
                       Text="אירוע חדש"
                       Style="{ThemeResource SubtitleTextBlockStyle}"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                       HorizontalAlignment="Center"/>
        </Border>

        <ScrollViewer Grid.Row="2" Padding="16,0,16,8" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">

                <StackPanel Spacing="4">
                    <TextBlock Text="כותרת" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                    <TextBox x:Name="TitleBox" PlaceholderText="כותרת האירוע"/>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="תיאור (אופציונלי)" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                    <TextBox x:Name="DescriptionBox"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="60"
                             PlaceholderText="פרטים נוספים..."/>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="תאריך" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                    <ComboBox x:Name="DateModeCombo"
                              HorizontalAlignment="Stretch"
                              SelectionChanged="DateModeCombo_SelectionChanged">
                        <ComboBoxItem Content="עברי" Tag="Heb"/>
                        <ComboBoxItem Content="לועזי" Tag="Greg"/>
                    </ComboBox>

                    <CalendarDatePicker x:Name="GregDatePicker"
                                        HorizontalAlignment="Stretch"
                                        PlaceholderText="בחר תאריך לועזי"/>

                    <Grid x:Name="HebDatePanel" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="HebDayCombo" Grid.Column="0" Margin="0,0,4,0" Header="יום"/>
                        <ComboBox x:Name="HebMonthCombo" Grid.Column="1" Margin="2,0,2,0" Header="חודש"/>
                        <NumberBox x:Name="HebYearBox" Grid.Column="2" Margin="4,0,0,0" Header="שנה" SpinButtonPlacementMode="Compact"/>
                    </Grid>
                </StackPanel>

                <StackPanel Spacing="4">
                    <ToggleSwitch x:Name="AllDaySwitch"
                                  Header="כל היום"
                                  OnContent="כן" OffContent="לא"
                                  Toggled="AllDaySwitch_Toggled"/>
                    <Grid x:Name="TimePanel">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TimePicker x:Name="StartTimePicker" Grid.Column="0" Margin="0,0,4,0" Header="שעת התחלה" ClockIdentifier="24HourClock"/>
                        <NumberBox x:Name="DurationMinutesBox" Grid.Column="1" Margin="4,0,0,0" Header="משך (דק')" Minimum="0" SpinButtonPlacementMode="Compact"/>
                    </Grid>
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="חזרתיות" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                    <ComboBox x:Name="RecurrenceCombo"
                              HorizontalAlignment="Stretch"
                              SelectionChanged="RecurrenceCombo_SelectionChanged">
                        <ComboBoxItem Content="ללא" Tag="None"/>
                        <ComboBoxItem Content="יומי (לועזי)" Tag="DailyGregorian"/>
                        <ComboBoxItem Content="שבועי (לועזי)" Tag="WeeklyGregorian"/>
                        <ComboBoxItem Content="חודשי (לועזי)" Tag="MonthlyGregorian"/>
                        <ComboBoxItem Content="שנתי (לועזי)" Tag="YearlyGregorian"/>
                        <ComboBoxItem Content="חודשי (עברי)" Tag="MonthlyHebrew"/>
                        <ComboBoxItem Content="שנתי (עברי) – יארצייט" Tag="YearlyHebrew"/>
                    </ComboBox>

                    <StackPanel x:Name="RecurrenceDetailsPanel" Spacing="6" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <NumberBox x:Name="IntervalBox" Grid.Column="0" Margin="0,0,4,0" Header="כל" Minimum="1" Value="1" SpinButtonPlacementMode="Compact"/>
                            <CalendarDatePicker x:Name="UntilPicker" Grid.Column="1" Margin="4,0,0,0" Header="עד תאריך (אופציונלי)"/>
                        </Grid>

                        <StackPanel x:Name="WeekdaysPanel" Visibility="Collapsed" Spacing="4">
                            <TextBlock Text="ימים בשבוע" Style="{ThemeResource CaptionTextBlockStyle}"/>
                            <StackPanel Orientation="Horizontal" Spacing="4" FlowDirection="LeftToRight">
                                <CheckBox x:Name="ChkSun" Content="א"/>
                                <CheckBox x:Name="ChkMon" Content="ב"/>
                                <CheckBox x:Name="ChkTue" Content="ג"/>
                                <CheckBox x:Name="ChkWed" Content="ד"/>
                                <CheckBox x:Name="ChkThu" Content="ה"/>
                                <CheckBox x:Name="ChkFri" Content="ו"/>
                                <CheckBox x:Name="ChkSat" Content="ש"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel Spacing="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="תזכורות" Style="{ThemeResource BodyStrongTextBlockStyle}" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Click="OnAddReminder">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE710;" FontSize="12"/>
                                <TextBlock Text="הוסף תזכורת"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                    <StackPanel x:Name="RemindersPanel" Spacing="8"/>
                </StackPanel>

                <InfoBar x:Name="ValidationBar"
                         IsOpen="False"
                         Severity="Warning"
                         IsClosable="False"/>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="3"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              Padding="16,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="DeleteButton"
                    Grid.Column="0"
                    Click="OnDelete"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE74D;" FontSize="12"/>
                    <TextBlock Text="מחק"/>
                </StackPanel>
            </Button>
            <Button Grid.Column="2" Content="ביטול" Click="OnCancel" Margin="0,0,8,0" MinWidth="90"/>
            <Button Grid.Column="3"
                    Content="שמור"
                    Style="{ThemeResource AccentButtonStyle}"
                    Click="OnSave"
                    MinWidth="90"/>
        </Grid>
    </Grid>
</Window>
