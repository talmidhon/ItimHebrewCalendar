<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ItimHebrewCalendar.Windows.CalendarPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ItimHebrewCalendar.Windows">

    <Grid x:Name="RootGrid">
        <Grid.Resources>
            <!-- Defined locally because XamlControlsResources doesn't always load this style in unpackaged WinUI 3. -->
            <Style x:Key="SubtleButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="Background" Value="{ThemeResource SubtleFillColorTransparentBrush}"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="36">
            <StackPanel Orientation="Horizontal"
                        Spacing="10"
                        VerticalAlignment="Center"
                        Margin="14,0,0,0">
                <Image x:Name="TitleBarIcon"
                       Width="16" Height="16"
                       VerticalAlignment="Center"/>
                <TextBlock Text="עיתים"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="14,4,14,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Click="OnAddEventClick" Padding="8,4" ToolTipService.ToolTip="הוסף אירוע חדש">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xE710;" FontSize="11"/>
                    <TextBlock Text="אירוע חדש" FontSize="12"/>
                </StackPanel>
            </Button>

            <Border Grid.Column="2"
                    CornerRadius="12"
                    Background="{ThemeResource ControlFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource ControlElevationBorderBrush}"
                    BorderThickness="1"
                    Padding="2">
                <StackPanel Orientation="Horizontal" Spacing="2">
                    <ToggleButton x:Name="DailyViewToggle"
                                  Content="יומי"
                                  Style="{StaticResource SegmentedToggleStyle}"
                                  MinWidth="56"
                                  Padding="12,3"
                                  FontSize="12"
                                  Click="OnSegToggleClick"/>
                    <ToggleButton x:Name="MonthlyViewToggle"
                                  Content="חודשי"
                                  Style="{StaticResource SegmentedToggleStyle}"
                                  MinWidth="56"
                                  Padding="12,3"
                                  FontSize="12"
                                  IsChecked="True"
                                  Click="OnSegToggleClick"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="CalendarView" Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border x:Name="TodayCard"
                    Grid.Row="0"
                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                    CornerRadius="8"
                    Margin="14,4,14,10"
                    Padding="16,10">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock x:Name="TxtTodayHebrew"
                               Style="{ThemeResource SubtitleTextBlockStyle}"
                               Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Text="..."/>
                    <TextBlock x:Name="TxtTodayGregorian"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                               Opacity="0.85"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,0"
                               Text="..."/>
                    <StackPanel x:Name="AfterSunsetPanel"
                                Orientation="Horizontal"
                                Spacing="4"
                                HorizontalAlignment="Center"
                                Margin="0,3,0,0"
                                Visibility="Collapsed">
                        <FontIcon Glyph="&#xE706;"
                                  FontSize="12"
                                  Foreground="#FFFFD080"/>
                        <TextBlock Text="לאחר השקיעה"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtTodayOmer"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"
                               Visibility="Collapsed"/>
                    <TextBlock x:Name="TxtTempleTimer"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                               Opacity="0.85"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,3,0,0"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1" Margin="14,0,14,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{ThemeResource SubtleButtonStyle}"
                        Click="OnPrevMonth"
                        Width="32" Height="32"
                        Padding="0">
                    <FontIcon Glyph="&#xE76C;" FontSize="12"/>
                </Button>

                <Button Grid.Column="1"
                        Style="{ThemeResource SubtleButtonStyle}"
                        Click="OnTodayClick"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Padding="8,4">
                    <StackPanel>
                        <TextBlock x:Name="TxtMonthHeb"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TxtMonthGreg"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="2"
                        Style="{ThemeResource SubtleButtonStyle}"
                        Click="OnNextMonth"
                        Width="32" Height="32"
                        Padding="0">
                    <FontIcon Glyph="&#xE76B;" FontSize="12"/>
                </Button>
            </Grid>

            <Grid Grid.Row="2" Margin="14,0,14,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="א" HorizontalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock Grid.Column="1" Text="ב" HorizontalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock Grid.Column="2" Text="ג" HorizontalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock Grid.Column="3" Text="ד" HorizontalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock Grid.Column="4" Text="ה" HorizontalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock Grid.Column="5" Text="ו" HorizontalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock Grid.Column="6" Text="ש" HorizontalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" FontWeight="SemiBold" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
            </Grid>

            <Grid x:Name="DaysGrid" Grid.Row="3" Margin="12,2,12,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="48"/>
                    <RowDefinition Height="48"/>
                    <RowDefinition Height="48"/>
                    <RowDefinition Height="48"/>
                    <RowDefinition Height="48"/>
                    <RowDefinition Height="48"/>
                </Grid.RowDefinitions>
            </Grid>

            <Border Grid.Row="4"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="14,0,14,10"
                    Padding="12,8">
                <StackPanel Spacing="3">
                    <TextBlock x:Name="TxtParasha"
                               Style="{ThemeResource BodyStrongTextBlockStyle}"
                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                    <TextBlock x:Name="TxtCandleLighting"
                               Style="{ThemeResource BodyTextBlockStyle}"/>
                    <TextBlock x:Name="TxtHavdalah"
                               Style="{ThemeResource BodyTextBlockStyle}"/>
                </StackPanel>
            </Border>

            <Grid Grid.Row="6"
                  Background="{ThemeResource LayerFillColorDefaultBrush}"
                  Padding="14,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="היום"
                        Style="{ThemeResource AccentButtonStyle}"
                        Click="OnTodayClick"
                        HorizontalAlignment="Left"
                        MinWidth="80"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <Button Click="OnOpenMainWindow" ToolTipService.ToolTip="פתח חלון מלא">
                        <FontIcon Glyph="&#xE787;" FontSize="14"/>
                    </Button>
                    <Button Click="OnZmanimClick" ToolTipService.ToolTip="זמני היום">
                        <FontIcon Glyph="&#xE706;" FontSize="14"/>
                    </Button>
                    <Button Click="OnConverterClick" ToolTipService.ToolTip="ממיר תאריכים">
                        <FontIcon Glyph="&#xE8AB;" FontSize="14"/>
                    </Button>
                    <Button Click="OnSettingsClick" ToolTipService.ToolTip="הגדרות">
                        <FontIcon Glyph="&#xE713;" FontSize="14"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>

        <Grid x:Name="DetailsView" Grid.Row="2" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Inside an RTL container, HorizontalAlignment=Left places the button on the visual right. -->
            <Button Grid.Row="0"
                    Style="{ThemeResource SubtleButtonStyle}"
                    Click="OnBackToCalendar"
                    HorizontalAlignment="Left"
                    Margin="10,4,10,2"
                    Padding="8,6">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE72B;" FontSize="12"/>
                    <TextBlock Text="חזרה ללוח"
                               Style="{ThemeResource BodyTextBlockStyle}"/>
                </StackPanel>
            </Button>

            <Border Grid.Row="1"
                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                    CornerRadius="8"
                    Margin="14,2,14,10"
                    Padding="18,12">
                <StackPanel Spacing="3">
                    <TextBlock x:Name="DetailsHebrew"
                               Style="{ThemeResource SubtitleTextBlockStyle}"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                    <TextBlock x:Name="DetailsGregorian"
                               Style="{ThemeResource BodyTextBlockStyle}"
                               HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                               Opacity="0.85"/>
                    <TextBlock x:Name="DetailsDayOfWeek"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                               Opacity="0.85"/>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="2" Padding="14,0,14,14" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="10">
                    <StackPanel x:Name="DetailsEventsSection" Spacing="6" Visibility="Collapsed">
                        <TextBlock Text="אירועים ביום זה"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                   Margin="4,0,4,2"/>
                        <StackPanel x:Name="DetailsEventsPanel" Spacing="6"/>
                    </StackPanel>

                    <StackPanel x:Name="DetailsZmanimSection" Spacing="6">
                        <TextBlock Text="זמני היום"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                   Margin="4,8,4,2"/>
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14,4">
                            <StackPanel x:Name="DetailsZmanimPanel"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid x:Name="DailyView" Grid.Row="2" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Merged header: prev arrow | accent date card | next arrow.
                 Arrows stretch vertically to match the card height. -->
            <Grid Grid.Row="0" Margin="14,4,14,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Click="OnDailyPrev"
                        Style="{StaticResource SubtleButtonStyle}"
                        VerticalAlignment="Stretch"
                        Width="40"
                        CornerRadius="8"
                        Padding="0"
                        ToolTipService.ToolTip="היום הקודם">
                    <FontIcon Glyph="&#xE76C;" FontSize="13"/>
                </Button>

                <Button Grid.Column="1" Click="OnDailyToday"
                        Style="{ThemeResource AccentButtonStyle}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        CornerRadius="8"
                        Margin="6,0,6,0"
                        Padding="14,10"
                        ToolTipService.ToolTip="חזרה להיום">
                    <StackPanel Spacing="2" HorizontalAlignment="Center">
                        <TextBlock x:Name="DailyHeaderHeb"
                                   Style="{ThemeResource SubtitleTextBlockStyle}"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                        <TextBlock x:Name="DailyHeaderGreg"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   HorizontalAlignment="Center"
                                   Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                   Opacity="0.9"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="2" Click="OnDailyNext"
                        Style="{StaticResource SubtleButtonStyle}"
                        VerticalAlignment="Stretch"
                        Width="40"
                        CornerRadius="8"
                        Padding="0"
                        ToolTipService.ToolTip="היום הבא">
                    <FontIcon Glyph="&#xE76B;" FontSize="13"/>
                </Button>
            </Grid>

            <ScrollViewer Grid.Row="1" Padding="14,0,14,12" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="10">
                    <TextBlock Text="אירועים ביום זה"
                               Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                    <StackPanel x:Name="DailyEventsSection" Spacing="6" Visibility="Collapsed">
                        <StackPanel x:Name="DailyEventsPanel" Spacing="6"/>
                    </StackPanel>

                    <StackPanel x:Name="DailyZmanimSection" Spacing="6">
                        <TextBlock Text="זמני היום"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                   Margin="0,4,0,2"/>
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14,4">
                            <StackPanel x:Name="DailyZmanimPanel"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
